{
  "realm": "keycloak-realm",
  "enabled": true,
  "roles": {
    "realm": [
      {
        "name": "ADMIN",
        "composite": false,
        "clientRole": false
      }
    ]
  },
  "clients": [
    {
      "clientId": "booking-client-credentials",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "secret",
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "defaultClientScopes": [
        "openid",
        "email",
        "profile"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-booking-client-credentials",
      "enabled": true,
      "serviceAccountClientId": "booking-client-credentials",
      "realmRoles": [
        "ADMIN",
        "default-roles-keycloak-realm"
      ]
    }
  ],
  "defaultDefaultClientScopes": [
    "openid",
    "email",
    "profile",
    "roles"
  ]
}
